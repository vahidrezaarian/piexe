<Window x:Class="Piexe.ScreenshotTaker"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Piexe"
        xmlns:wpfgif="http://wpfanimatedgif.codeplex.com"
        mc:Ignorable="d"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Topmost="True"
        Cursor="Cross"
        Title="Piexe" Height="450" Width="800">
    <Window.Background>
        <SolidColorBrush Opacity="0.1" Color="Black"/>
    </Window.Background>
    <Grid>
        <Rectangle x:Name="SelectingRectangle" ClipToBounds="True">
            <Rectangle.Fill>
                <SolidColorBrush Color="Black" Opacity="0.5"/>
            </Rectangle.Fill>
        </Rectangle>
        <Path x:Name="SelectingRectangleStroke"
              Fill="Transparent"
              Stroke="White" StrokeThickness="1"
              Visibility="Collapsed"/>
        <Border BorderBrush="Black" BorderThickness="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Padding="10">
            <Border.Effect>
                <DropShadowEffect Color="CornflowerBlue" Direction="0" ShadowDepth="0" BlurRadius="10" Opacity="1"/>
            </Border.Effect>
        </Border>
        <Border x:Name="ToolBarBorder" MinHeight="3" MinWidth="60" Background="#333333" BorderBrush="Transparent" CornerRadius="0,0,10,10" Padding="10"
                HorizontalAlignment="Center" VerticalAlignment="Top" Cursor="Arrow">
            <StackPanel Orientation="Vertical" x:Name="ToolBarStack" HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="AnalyzeToggleButton" Background="DeepSkyBlue" BorderBrush="Transparent" Height="25" Click="AnalyzeToggleButton_Click">
                        <TextBlock Text="Scan" HorizontalAlignment="Center" Margin="10,1,10,1" Foreground="White" VerticalAlignment="Center" TextAlignment="Center" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                        <Button.Style>
                            <Style TargetType="{x:Type Button}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type Button}">
                                            <Border x:Name="Border"
                                                    BorderBrush="DimGray"
                                                    Background="{TemplateBinding Background}"
                                                    BorderThickness="1,1,0,1"
                                                    Height="25"
                                                    CornerRadius="12,0,0,12"
                                                    SnapsToDevicePixels="True">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"/>
                                            </Border>

                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Border" Property="BorderBrush" Value="White"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button x:Name="ScreenshotToggleButton" Margin="0,0,10,0" Background="DarkGray" BorderBrush="Transparent" Height="25" Click="ScreenshotToggleButton_Click">
                        <TextBlock Text="Screenshot" HorizontalAlignment="Center" Foreground="White" Margin="10,1,10,1" VerticalAlignment="Center" TextAlignment="Center" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                        <Button.Style>
                            <Style TargetType="{x:Type Button}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type Button}">
                                            <Border x:Name="Border"
                                    BorderBrush="DimGray"
                                    Background="{TemplateBinding Background}"
                                    BorderThickness="0,1,1,1"
                                    Height="25"
                                    CornerRadius="0,12,12,0"
                                    SnapsToDevicePixels="True">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Content="{TemplateBinding Content}"
                                                      ContentTemplate="{TemplateBinding ContentTemplate}"/>
                                            </Border>

                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Border" Property="BorderBrush" Value="White"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button x:Name="CaptureButton" Background="DeepSkyBlue" BorderBrush="Transparent" HorizontalAlignment="Center" VerticalAlignment="Center" Click="CaptureButton_Click">
                        <TextBlock Text="Capture the whole screen" HorizontalAlignment="Center" Margin="10,0,10,0" Foreground="White" VerticalAlignment="Center" TextAlignment="Center" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                        <Button.Style>
                            <Style TargetType="{x:Type Button}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type Button}">
                                            <Border x:Name="Border"
                                    BorderBrush="DimGray"
                                    Background="DeepSkyBlue"
                                    BorderThickness="1"
                                    Height="25"
                                    CornerRadius="12"
                                    SnapsToDevicePixels="True">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"/>
                                            </Border>

                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Border" Property="BorderBrush" Value="White"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <StackPanel x:Name="IteratorLevelSelectionStack" Height="30" Orientation="Horizontal" Margin="0,5,0,0" HorizontalAlignment="Center">
                    <TextBlock Text="Detect and sort text by: " FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                    
                    <Button x:Name="BlockToggleButton" Background="DeepSkyBlue" BorderBrush="Transparent" Height="25" Click="BlockToggleButton_Click">
                        <TextBlock Text="Block" HorizontalAlignment="Center" Margin="10,1,10,1" Foreground="White" VerticalAlignment="Center" TextAlignment="Center" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                        <Button.Style>
                            <Style TargetType="{x:Type Button}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type Button}">
                                            <Border x:Name="Border"
                BorderBrush="DimGray"
                Background="{TemplateBinding Background}"
                BorderThickness="1,1,1,1"
                Height="25"
                CornerRadius="12,0,0,12"
                SnapsToDevicePixels="True">
                                                <ContentPresenter HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Content="{TemplateBinding Content}"
                              ContentTemplate="{TemplateBinding ContentTemplate}"/>
                                            </Border>

                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Border" Property="BorderBrush" Value="White"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button x:Name="LineToggleButton" Margin="0" Background="DarkGray" BorderBrush="Transparent" Height="25" Click="LineToggleButton_Click">
                        <TextBlock Text="Line" HorizontalAlignment="Center" Foreground="White" Margin="10,1,10,1" VerticalAlignment="Center" 
                                   TextAlignment="Center" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                        <Button.Style>
                            <Style TargetType="{x:Type Button}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type Button}">
                                            <Border x:Name="Border"
                                                    BorderBrush="DimGray"
                                                    Background="{TemplateBinding Background}"
                                                    BorderThickness="0,1,1,1"
                                                    Height="25"
                                                    CornerRadius="0"
                                                    SnapsToDevicePixels="True">
                                                <ContentPresenter HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Content="{TemplateBinding Content}"
                  ContentTemplate="{TemplateBinding ContentTemplate}"/>
                                            </Border>

                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Border" Property="BorderBrush" Value="White"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button x:Name="WordToggleButton" Margin="0" Background="DarkGray" BorderBrush="Transparent" Height="25" Click="WordToggleButton_Click">
                        <TextBlock Text="Word" HorizontalAlignment="Center" Foreground="White" Margin="10,1,10,1" VerticalAlignment="Center" TextAlignment="Center" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                        <Button.Style>
                            <Style TargetType="{x:Type Button}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type Button}">
                                            <Border x:Name="Border"
                                  BorderBrush="DimGray"
                                  Background="{TemplateBinding Background}"
                                  BorderThickness="0,1,1,1"
                                  Height="25"
                                  CornerRadius="0"
                                  SnapsToDevicePixels="True">
                                                <ContentPresenter HorizontalAlignment="Center"
VerticalAlignment="Center"
Content="{TemplateBinding Content}"
ContentTemplate="{TemplateBinding ContentTemplate}"/>
                                            </Border>

                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Border" Property="BorderBrush" Value="White"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button x:Name="SymbolToggleButton" Margin="0" Background="DarkGray" BorderBrush="Transparent" Height="25" Click="SymbolToggleButton_Click">
                        <TextBlock Text="Symbol" HorizontalAlignment="Center" Foreground="White" Margin="10,1,10,1" VerticalAlignment="Center" TextAlignment="Center" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                        <Button.Style>
                            <Style TargetType="{x:Type Button}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type Button}">
                                            <Border x:Name="Border"
                                  BorderBrush="DimGray"
                                  Background="{TemplateBinding Background}"
                                  BorderThickness="0,1,1,1"
                                  Height="25"
                                  CornerRadius="0"
                                  SnapsToDevicePixels="True">
                                                <ContentPresenter HorizontalAlignment="Center"
VerticalAlignment="Center"
Content="{TemplateBinding Content}"
ContentTemplate="{TemplateBinding ContentTemplate}"/>
                                            </Border>

                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Border" Property="BorderBrush" Value="White"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button x:Name="ParagraphToggleButton" Margin="0" Background="DarkGray" BorderBrush="Transparent" Height="25" Click="ParagraphToggleButton_Click">
                        <TextBlock Text="Paragraph" HorizontalAlignment="Center" Foreground="White" Margin="10,1,10,1" VerticalAlignment="Center" TextAlignment="Center" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                        <Button.Style>
                            <Style TargetType="{x:Type Button}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type Button}">
                                            <Border x:Name="Border"
                BorderBrush="DimGray"
                Background="{TemplateBinding Background}"
                BorderThickness="0,1,1,1"
                Height="25"
                CornerRadius="0,12,12,0"
                SnapsToDevicePixels="True">
                                                <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Content="{TemplateBinding Content}"
                                  ContentTemplate="{TemplateBinding ContentTemplate}"/>
                                            </Border>

                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Border" Property="BorderBrush" Value="White"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
