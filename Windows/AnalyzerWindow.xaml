<Window x:Class="Piexe.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Piexe"
        xmlns:wpfgif="http://wpfanimatedgif.codeplex.com"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        WindowStyle="SingleBorderWindow"
        AllowDrop="True"
        ThemeMode="System"
        PreviewDragEnter="Window_PreviewDragEnter"
        PreviewDragLeave="Window_PreviewDragLeave"
        PreviewDrop="Window_PreviewDrop"
        ShowInTaskbar="True"
        Title="Piexe" MinWidth="200" MinHeight="70" SizeToContent="WidthAndHeight">
    <Grid x:Name="WindowGrid">
        <Grid x:Name="WindowContentGrid">
            <Grid.RowDefinitions>
                <RowDefinition x:Name="WindowContentScrollViewRow" Height="*"/>
                <RowDefinition x:Name="WindowContentMessagingRow" MaxHeight="100"/>
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0" x:Name="WindowContentScrollView" HorizontalAlignment="Stretch" VerticalAlignment="Top" 
                      ScrollViewer.VerticalScrollBarVisibility="Auto" Margin="15,15,15,15">
                <StackPanel x:Name="MainContainer" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            </ScrollViewer>

            <StackPanel Grid.Row="1" Orientation="Vertical" VerticalAlignment="Bottom" HorizontalAlignment="Stretch">
                <Grid Margin="15,5,15,0" x:Name="PageIteratorSelectionWidget" Visibility="Collapsed">
                    <Button HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsEnabled="False" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Vertical" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <TextBlock Text="Text detection iteration level" FontWeight="Bold"
                                       HorizontalAlignment="Left" Margin="10,10,0,0"/>
                            <TextBlock Text="How do you want the app to detect and sort the text?"
                                       HorizontalAlignment="Left"  Margin="10,0,10,10"/>
                        </StackPanel>
                        <ComboBox Grid.Column="1" x:Name="PageIteratorSelectionComboBox" HorizontalAlignment="Right"  VerticalAlignment="Center"
                                  SelectionChanged="PageIteratorSelectionComboBox_SelectionChanged" Margin="10"/>
                    </Grid>
                </Grid>
                
                <TextBlock x:Name="MessageTextBlock" Text="Drag and drop images to scan"
                           HorizontalAlignment="Center" FontWeight="SemiBold"  Margin="15,10,15,15"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="ErrorTextBlock" Foreground="Red" Visibility="Collapsed"
                           HorizontalAlignment="Center" FontWeight="SemiBold"  Margin="15,10,15,15"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <Grid x:Name="DropMessage" Visibility="Collapsed" VerticalAlignment="Stretch">
            <Border CornerRadius="15,15,0,0" BorderThickness="0" Background="Black" Opacity="0.5"/>

            <TextBlock Text="Drop to scan" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#FAFAFA" 
                       FontWeight="Bold" Margin="40" Visibility="Visible"/>
        </Grid>

        <Grid x:Name="ScanningGif" Visibility="Collapsed" VerticalAlignment="Stretch">
            <Border CornerRadius="15,15,0,0" BorderThickness="0" Background="Black" Opacity="0.5" Visibility="Visible"/>

            <StackPanel Orientation="Vertical">
                <Image x:Name="QRCodeGif"  
                   wpfgif:ImageBehavior.AnimatedSource="/Assets/LoadingGif.gif"
                   wpfgif:ImageBehavior.AutoStart="True"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   Width="50"
                   Height="50"
                   Margin="0,10,0,10"
                   Stretch="UniformToFill"/>

                <TextBlock Text="Scanning..." HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#FAFAFA" 
                           FontWeight="Bold" Margin="0,0,0,50" Visibility="Visible"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
