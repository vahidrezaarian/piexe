<Window x:Class="Piexe.ScreenshotTaker"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Piexe"
        xmlns:wpfgif="http://wpfanimatedgif.codeplex.com"
        mc:Ignorable="d"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Topmost="True"
        ThemeMode="System"
        Cursor="Cross"
        Title="Piexe" Height="450" Width="800">
    <Window.Background>
        <SolidColorBrush Color="Transparent"/>
    </Window.Background>
    <Grid>
        <Rectangle x:Name="SelectingRectangle" ClipToBounds="True">
            <Rectangle.Fill>
                <SolidColorBrush Color="Black" Opacity="0.5"/>
            </Rectangle.Fill>
        </Rectangle>
        <Path x:Name="SelectingRectangleStroke"
              Fill="Transparent"
              Stroke="White" StrokeThickness="1"
              Visibility="Collapsed"/>
        <Border BorderBrush="Black" BorderThickness="1" Opacity="0.5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Padding="10">
            <Border.Effect>
                <DropShadowEffect Color="CornflowerBlue" Direction="0" ShadowDepth="0" BlurRadius="10" Opacity="1"/>
            </Border.Effect>
        </Border>

        <Border x:Name="ToolBarBorder" Background="#333333" BorderBrush="Gray" BorderThickness="1,0,1,1" CornerRadius="0,0,15,15" 
                HorizontalAlignment="Center" VerticalAlignment="Top" Cursor="Arrow">
            <StackPanel x:Name="ToolBarStack" Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10">
                <Grid x:Name="ToolbardButtonsGrid" Height="25">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                        <ToggleButton x:Name="AnalyzeToggleButton" Click="AnalyzeToggleButton_Click" VerticalAlignment="Stretch"
                                      IsChecked="True" HorizontalAlignment="Left">
                            <TextBlock Text="Scan" HorizontalAlignment="Center" Margin="10,0,10,0"
                                       VerticalAlignment="Center" TextAlignment="Center" FontWeight="SemiBold"/>
                        </ToggleButton>

                        <ToggleButton x:Name="ScreenshotToggleButton" Click="ScreenshotToggleButton_Click"
                                      VerticalAlignment="Stretch" HorizontalAlignment="Right" Margin="2,0,0,0">
                            <TextBlock Text="Screenshot" HorizontalAlignment="Center" Margin="10,1,10,1"
                                       VerticalAlignment="Center" TextAlignment="Center" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                        </ToggleButton>
                    </StackPanel>

                    <Button Grid.Column="1" x:Name="CaptureButton" Margin="10,0,0,0" 
                            VerticalAlignment="Stretch" HorizontalAlignment="Right" Click="CaptureButton_Click">
                        <TextBlock Text="Capture the whole screen" HorizontalAlignment="Center" Margin="10,0,10,0"
                                   VerticalAlignment="Center" TextAlignment="Center" FontWeight="SemiBold"/>
                    </Button>
                </Grid>

                <Grid x:Name="IteratorLevelSelectionGrid" Height="70"  VerticalAlignment="Center">
                    <Button HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="0,10,0,0" IsEnabled="False"/>
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Vertical" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <TextBlock Text="Text detection iteration level" FontWeight="Bold"
                                       HorizontalAlignment="Left" Margin="10,10,0,0"/>
                            <TextBlock Text="How do you want the app to detect and sort the text?"
                                       HorizontalAlignment="Left"  Margin="10,0,10,10"/>
                        </StackPanel>
                        <ComboBox Grid.Column="1" x:Name="PageIteratorSelectionComboBox" HorizontalAlignment="Right" 
                                  VerticalAlignment="Center" SelectionChanged="PageIteratorSelectionComboBox_SelectionChanged" 
                                  SelectedIndex="0" Margin="10"/>
                    </Grid>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>
